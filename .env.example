# TradingIA - Configuración de Variables de Entorno

# ========== APIs DE DATOS EN TIEMPO REAL ==========

# CoinGecko - GRATIS, sin API key (completamente gratuito)
NEXT_PUBLIC_COINGECKO_ENABLED=true

# Finnhub - Plan gratuito: 60 calls/min
# Obtén tu key en: https://finnhub.io/register
NEXT_PUBLIC_FINNHUB_KEY=your_finnhub_api_key_here
NEXT_PUBLIC_FINNHUB_ENABLED=true

# NewsAPI - Plan gratuito: 100 requests/día
# Obtén tu key en: https://newsapi.org/
NEXT_PUBLIC_NEWSAPI_KEY=your_newsapi_api_key_here
NEXT_PUBLIC_NEWSAPI_ENABLED=true

# Alpha Vantage - Plan gratuito: 5 calls/min
# Obtén tu key en: https://www.alphavantage.co/
NEXT_PUBLIC_ALPHAVANTAGE_KEY=your_alphavantage_api_key_here
NEXT_PUBLIC_ALPHAVANTAGE_ENABLED=true

# ========== CONFIGURACIÓN DE CACHE ==========

# TTL de cache en milisegundos (por defecto 60 segundos)
NEXT_PUBLIC_API_CACHE_TTL=60000

# ========== API ENDPOINTS INTERNOS ==========

NEXT_PUBLIC_API_MARKET_URL=http://localhost:3000/api/market
NEXT_PUBLIC_API_AI_URL=http://localhost:3000/api/ai

# ========== CONFIGURACIÓN DE LA APLICACIÓN ==========

NEXT_PUBLIC_APP_NAME=TradingIA
NEXT_PUBLIC_APP_DESCRIPTION=Plataforma de Análisis de Mercado Financiero con IA

# ========== MODO DESARROLLO ==========

NODE_ENV=development

# Nota: Las variables NEXT_PUBLIC_ son accesibles en el navegador

