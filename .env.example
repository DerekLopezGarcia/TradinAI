# ==================== APIS DE MERCADO ====================

# Finnhub API - Datos de acciones y WebSocket en tiempo real
# Obtén tu API key en: https://finnhub.io
# Rate limit gratuito: 60 calls/min
NEXT_PUBLIC_FINNHUB_KEY=tu_api_key_de_finnhub

# Alpha Vantage API - Datos históricos de acciones e indicadores técnicos
# Obtén tu API key en: https://www.alphavantage.co
# Rate limit gratuito: 5 calls/min
NEXT_PUBLIC_ALPHAVANTAGE_KEY=tu_api_key_de_alphavantage

# NewsAPI - Noticias de mercado y análisis
# Obtén tu API key en: https://newsapi.org
# Rate limit gratuito: 100 calls/día
NEXT_PUBLIC_NEWS_API_KEY=tu_api_key_de_newsapi

# ==================== COINGECKO ====================

# CoinGecko - Datos de criptomonedas
# No requiere API key para el plan gratuito (rate limit: 10-50 calls/min)
# Para mayor rate limit en producción, obtén tu API key en: https://www.coingecko.com/api
# NEXT_PUBLIC_COINGECKO_API_KEY=tu_api_key_de_coingecko (opcional)

# ==================== INTELIGENCIA ARTIFICIAL ====================

# z-ai-web-dev-sdk
# Ya funciona con la configuración por defecto
# No requiere variables de entorno adicionales
# La IA se inicializa automáticamente en los endpoints

# ==================== CONFIGURACIÓN DE APLICACIÓN ====================

# Entorno
NODE_ENV=development

# URL Base (usar para llamadas API en servidor)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ==================== NOTAS IMPORTANTES ====================

# 1. Copia este archivo a .env.local
# 2. Reemplaza los valores con tus API keys reales
# 3. NO subas .env.local a Git (está en .gitignore)
# 4. Las variables NEXT_PUBLIC_ se exponen en el navegador (es seguro)
# 5. Para desarrollo, los valores por defecto funcionarán pero con limitaciones

# ==================== PASOS PARA CONFIGURAR ====================

# 1. Registrate en cada servicio (todos tienen plan gratuito)
# 2. Obtén tus API keys
# 3. Copia este archivo: cp .env.example .env.local
# 4. Reemplaza los valores de ejemplo con tus keys reales
# 5. Reinicia el servidor: npm run dev

# Ver ENV_SETUP.md para guía detallada de configuración


